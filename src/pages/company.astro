---
export const prerender = false;

import { env } from "cloudflare:workers";
import "../styles/global.css";
import "../styles/company.css";

interface Company {
    slug: string;
    name: string;
    postal_code: string | null;
    address: string | null;
    phone: string | null;
    email: string | null;
    contact_person: string | null;
}

interface QaRow {
    id: number;
    category: string;
    question: string;
    answer: string;
}

const slug = Astro.url.searchParams.get("id")?.trim();
const db = env.DB;

const company = slug
    ? await db
          .prepare(
              `
				SELECT slug, name, postal_code, address, phone, email, contact_person
				FROM companies
				WHERE slug = ? AND is_active = 1
			`,
          )
          .bind(slug)
          .first<Company>()
    : null;

if (!company) {
    Astro.response.status = 404;
}

const commonQa = company
    ? (
          await db
              .prepare(
                  `
				SELECT id, category, question, answer
				FROM common_qa
				WHERE is_active = 1
				ORDER BY id
			`,
              )
              .all<QaRow>()
      ).results
    : [];

const companyQa = company
    ? (
          await db
              .prepare(
                  `
				SELECT id, category, question, answer
				FROM company_qa
				WHERE company_slug = ? AND is_active = 1
				ORDER BY id
			`,
              )
              .bind(company.slug)
              .all<QaRow>()
      ).results
    : [];

const categories = new Map<string, QaRow[]>();
for (const qa of [...commonQa, ...companyQa]) {
    const rows = categories.get(qa.category) ?? [];
    rows.push(qa);
    categories.set(qa.category, rows);
}

const categoryEntries = [...categories.entries()];
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta
            name="description"
            content={company
                ? `${company.name}のよくあるご質問`
                : "会社情報が見つかりません"}
        />
        <title>
            {
                company
                    ? `${company.name} | よくあるご質問`
                    : "ページが見つかりません"
            }
        </title>
    </head>
    <body>
        <main>
            {
                company ? (
                    <>
                        <header class="page-header">
                            <h1>Q&amp;A</h1>
                            <p class="page-ruby">よくあるご質問</p>
                        </header>

                        {categoryEntries.length > 0 ? (
                            <>
                                <div
                                    class="filters"
                                    aria-label="よくあるご質問の絞り込み"
                                >
                                    <label>
                                        <span class="visually-hidden">
                                            カテゴリ
                                        </span>
                                        <select id="category-filter">
                                            <option value="">
                                                すべてのカテゴリ
                                            </option>
                                            {categoryEntries.map(
                                                ([category], index) => (
                                                    <option
                                                        value={`category-${index}`}
                                                    >
                                                        {category}
                                                    </option>
                                                ),
                                            )}
                                        </select>
                                    </label>
                                    <label class="search-field">
                                        <span class="visually-hidden">
                                            質問と回答を検索
                                        </span>
                                        <span aria-hidden="true">⌕</span>
                                        <input
                                            id="qa-search"
                                            type="search"
                                            placeholder="質問と回答を検索"
                                            autocomplete="off"
                                        />
                                    </label>
                                </div>

                                <div id="qa-sections">
                                    {categoryEntries.map(
                                        ([category, rows], categoryIndex) => (
                                            <section
                                                class="qa-section"
                                                id={`category-${categoryIndex}`}
                                                data-category-id={`category-${categoryIndex}`}
                                            >
                                                <h2>{category}</h2>
                                                <div class="qa-list">
                                                    {rows.map((qa) => (
                                                        <details
                                                            class="qa-item"
                                                            data-search-text={`${qa.question} ${qa.answer}`.toLocaleLowerCase(
                                                                "ja",
                                                            )}
                                                        >
                                                            <summary class="qa-trigger">
                                                                <span class="question">
                                                                    <span
                                                                        class="q-mark"
                                                                        aria-hidden="true"
                                                                    >
                                                                        Q.
                                                                    </span>
                                                                    {
                                                                        qa.question
                                                                    }
                                                                </span>
                                                                <span
                                                                    class="indicator"
                                                                    aria-hidden="true"
                                                                />
                                                            </summary>
                                                            <div class="answer">
                                                                <p>
                                                                    {qa.answer}
                                                                </p>
                                                            </div>
                                                        </details>
                                                    ))}
                                                </div>
                                            </section>
                                        ),
                                    )}
                                </div>
                                <p id="no-results" class="empty-state" hidden>
                                    条件に一致する質問はありません。
                                </p>
                            </>
                        ) : (
                            <p class="empty-state">
                                現在、公開中のよくあるご質問はありません。
                            </p>
                        )}

                        <section
                            class="company-info"
                            aria-labelledby="company-info-heading"
                        >
                            <h2 id="company-info-heading">会社情報</h2>
                            <h3>{company.name}</h3>
                            <address class="company-details">
                                {(company.postal_code || company.address) && (
                                    <p>
                                        {company.postal_code && (
                                            <span>〒{company.postal_code}</span>
                                        )}
                                        {company.address && (
                                            <span>{company.address}</span>
                                        )}
                                    </p>
                                )}
                                {company.phone && (
                                    <p>
                                        <span>電話</span>{" "}
                                        <a href={`tel:${company.phone}`}>
                                            {company.phone}
                                        </a>
                                    </p>
                                )}
                                {company.email && (
                                    <p>
                                        <span>メール</span>{" "}
                                        <a href={`mailto:${company.email}`}>
                                            {company.email}
                                        </a>
                                    </p>
                                )}
                                {company.contact_person && (
                                    <p>
                                        <span>担当</span>{" "}
                                        {company.contact_person}
                                    </p>
                                )}
                            </address>
                        </section>
                    </>
                ) : (
                    <section class="not-found">
                        <p class="eyebrow">404</p>
                        <h1>会社情報が見つかりません</h1>
                        <p>
                            URLをご確認ください。会社が非公開になっている場合もあります。
                        </p>
                    </section>
                )
            }
        </main>

        <script src="../scripts/company.ts"></script>
    </body>
</html>
