---
export const prerender = false;

interface Company {
	slug: string;
	name: string;
	postal_code: string | null;
	address: string | null;
	phone: string | null;
	email: string | null;
	contact_person: string | null;
}

interface QaRow {
	id: number;
	category: string;
	question: string;
	answer: string;
}

const slug = Astro.url.searchParams.get('id')?.trim();
const db = Astro.locals.runtime.env.DB;

const company = slug
	? await db
			.prepare(`
				SELECT slug, name, postal_code, address, phone, email, contact_person
				FROM companies
				WHERE slug = ? AND is_active = 1
			`)
			.bind(slug)
			.first<Company>()
	: null;

if (!company) {
	Astro.response.status = 404;
}

const commonQa = company
	? (await db
			.prepare(`
				SELECT id, category, question, answer
				FROM common_qa
				WHERE is_active = 1
				ORDER BY id
			`)
			.all<QaRow>()).results
	: [];

const companyQa = company
	? (await db
			.prepare(`
				SELECT id, category, question, answer
				FROM company_qa
				WHERE company_slug = ? AND is_active = 1
				ORDER BY id
			`)
			.bind(company.slug)
			.all<QaRow>()).results
	: [];

const categories = new Map<string, QaRow[]>();
for (const qa of [...commonQa, ...companyQa]) {
	const rows = categories.get(qa.category) ?? [];
	rows.push(qa);
	categories.set(qa.category, rows);
}

const categoryEntries = [...categories.entries()];
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={company ? `${company.name}のよくあるご質問` : '会社情報が見つかりません'} />
		<title>{company ? `${company.name} | よくあるご質問` : 'ページが見つかりません'}</title>
	</head>
	<body>
		<main>
			{company ? (
				<>
					<header class="company-header">
						<p class="eyebrow">会社情報・よくあるご質問</p>
						<h1>{company.name}</h1>
						<address class="company-details">
							{(company.postal_code || company.address) && (
								<p>
									{company.postal_code && <span>〒{company.postal_code}</span>}
									{company.address && <span>{company.address}</span>}
								</p>
							)}
							{company.phone && <p><span>電話</span> <a href={`tel:${company.phone}`}>{company.phone}</a></p>}
							{company.email && <p><span>メール</span> <a href={`mailto:${company.email}`}>{company.email}</a></p>}
							{company.contact_person && <p><span>担当</span> {company.contact_person}</p>}
						</address>
					</header>

					{categoryEntries.length > 0 ? (
						<>
							<div class="filters" aria-label="よくあるご質問の絞り込み">
								<label>
									<span class="visually-hidden">カテゴリ</span>
									<select id="category-filter">
										<option value="">すべてのカテゴリ</option>
										{categoryEntries.map(([category], index) => (
											<option value={`category-${index}`}>{category}</option>
										))}
									</select>
								</label>
								<label class="search-field">
									<span class="visually-hidden">質問と回答を検索</span>
									<span aria-hidden="true">⌕</span>
									<input id="qa-search" type="search" placeholder="質問と回答を検索" autocomplete="off" />
								</label>
							</div>

							<div id="qa-sections">
								{categoryEntries.map(([category, rows], categoryIndex) => (
									<section class="qa-section" id={`category-${categoryIndex}`} data-category-id={`category-${categoryIndex}`}>
										<h2>{category}</h2>
										<div class="qa-list">
											{rows.map((qa, qaIndex) => {
												const answerId = `answer-${categoryIndex}-${qaIndex}`;
												return (
													<article class="qa-item" data-search-text={`${qa.question} ${qa.answer}`.toLocaleLowerCase('ja')}>
														<h3>
															<button type="button" class="qa-trigger" aria-expanded="false" aria-controls={answerId}>
																<span class="question"><span class="q-mark" aria-hidden="true">Q.</span>{qa.question}</span>
																<span class="indicator" aria-hidden="true">+</span>
															</button>
														</h3>
														<div class="answer" id={answerId} hidden>
															<p>{qa.answer}</p>
														</div>
													</article>
												);
											})}
										</div>
									</section>
								))}
							</div>
							<p id="no-results" class="empty-state" hidden>条件に一致する質問はありません。</p>
						</>
					) : <p class="empty-state">現在、公開中のよくあるご質問はありません。</p>}
				</>
			) : (
				<section class="not-found">
					<p class="eyebrow">404</p>
					<h1>会社情報が見つかりません</h1>
					<p>URLをご確認ください。会社が非公開になっている場合もあります。</p>
				</section>
			)}
		</main>

		<script>
			const searchInput = document.querySelector<HTMLInputElement>('#qa-search');
			const categorySelect = document.querySelector<HTMLSelectElement>('#category-filter');
			const sections = [...document.querySelectorAll<HTMLElement>('.qa-section')];
			const noResults = document.querySelector<HTMLElement>('#no-results');

			function applyFilters() {
				const query = searchInput?.value.trim().toLocaleLowerCase('ja') ?? '';
				const selectedCategory = categorySelect?.value ?? '';
				let visibleCount = 0;

				for (const section of sections) {
					const categoryMatches = !selectedCategory || section.dataset.categoryId === selectedCategory;
					let sectionCount = 0;
					for (const item of section.querySelectorAll<HTMLElement>('.qa-item')) {
						const searchMatches = !query || (item.dataset.searchText ?? '').includes(query);
						item.hidden = !categoryMatches || !searchMatches;
						if (!item.hidden) sectionCount += 1;
					}
					section.hidden = sectionCount === 0;
					visibleCount += sectionCount;
				}

				if (noResults) noResults.hidden = visibleCount !== 0;
			}

			searchInput?.addEventListener('input', applyFilters);
			categorySelect?.addEventListener('change', () => {
				applyFilters();
				const target = categorySelect.value && document.getElementById(categorySelect.value);
				if (target && !target.hidden) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
			});

			for (const trigger of document.querySelectorAll<HTMLButtonElement>('.qa-trigger')) {
				trigger.addEventListener('click', () => {
					const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
					const answer = document.getElementById(trigger.getAttribute('aria-controls') ?? '');
					trigger.setAttribute('aria-expanded', String(!isExpanded));
					if (answer) answer.hidden = isExpanded;
					const indicator = trigger.querySelector('.indicator');
					if (indicator) indicator.textContent = isExpanded ? '+' : '−';
				});
			}
		</script>
	</body>
</html>

<style is:global>
	:root {
		--color-bg: oklch(95.9% 0.01 87.5);
		--color-surface: oklch(98% 0.005 87.5);
		--color-border: oklch(88.4% 0.018 81.3);
		--color-ink: oklch(26.2% 0.007 67.5);
		--color-ink-muted: oklch(53.7% 0.019 70.3);
		--color-accent: oklch(67.2% 0.131 38.8);
		--color-accent-ink: oklch(98% 0.005 87.5);
		--font-sans: ui-sans-serif, -apple-system, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
	}

	* { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { margin: 0; background: var(--color-bg); color: var(--color-ink); font-family: var(--font-sans); }
	main { width: min(100% - 2rem, 54rem); margin: 0 auto; padding: clamp(2.5rem, 8vw, 6rem) 0 5rem; }
	.company-header { padding-bottom: 2.25rem; border-bottom: 1px solid var(--color-border); }
	.eyebrow { margin: 0 0 .7rem; color: var(--color-accent); font-size: .75rem; font-weight: 650; letter-spacing: .1em; text-transform: uppercase; }
	h1 { margin: 0; font-size: clamp(2rem, 6vw, 3.25rem); font-weight: 620; letter-spacing: -.035em; line-height: 1.12; }
	.company-details { display: grid; gap: .45rem; margin-top: 1.5rem; color: var(--color-ink-muted); font-size: .95rem; font-style: normal; line-height: 1.6; }
	.company-details p { display: flex; flex-wrap: wrap; gap: .3rem .8rem; margin: 0; }
	a { color: inherit; text-decoration-color: var(--color-border); text-underline-offset: .2em; }
	a:hover { color: var(--color-accent); }
	.filters { position: sticky; z-index: 10; top: 0; display: grid; grid-template-columns: minmax(12rem, .7fr) minmax(14rem, 1.3fr); gap: .75rem; margin: 1.5rem 0 2.75rem; padding: .75rem; background: color-mix(in oklch, var(--color-bg) 92%, transparent); border: 1px solid var(--color-border); border-radius: .75rem; backdrop-filter: blur(12px); }
	.filters label { min-width: 0; }
	select, input { width: 100%; height: 2.85rem; border: 1px solid var(--color-border); border-radius: .5rem; background: var(--color-surface); color: var(--color-ink); font: inherit; }
	select { padding: 0 2.25rem 0 .85rem; }
	.search-field { position: relative; }
	.search-field > span[aria-hidden] { position: absolute; top: 50%; left: .9rem; color: var(--color-ink-muted); transform: translateY(-50%); }
	input { padding: 0 .85rem 0 2.4rem; }
	select:focus-visible, input:focus-visible, .qa-trigger:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }
	.qa-section { scroll-margin-top: 6rem; margin-top: 2.75rem; }
	.qa-section h2 { display: flex; align-items: center; gap: .8rem; margin: 0 0 .65rem; color: var(--color-ink-muted); font-size: .78rem; font-weight: 650; letter-spacing: .09em; text-transform: uppercase; }
	.qa-section h2::after { width: 2.75rem; height: 2px; background: var(--color-accent); content: ""; }
	.qa-list { overflow: hidden; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: .8rem; }
	.qa-item + .qa-item { border-top: 1px solid var(--color-border); }
	.qa-item h3 { margin: 0; }
	.qa-trigger { display: flex; width: 100%; align-items: center; justify-content: space-between; gap: 1.5rem; padding: 1.15rem 1.25rem; border: 0; background: transparent; color: var(--color-ink); font: inherit; font-weight: 520; text-align: left; cursor: pointer; }
	.question { display: flex; gap: .65rem; line-height: 1.5; }
	.q-mark { color: var(--color-ink-muted); font-size: .85em; font-weight: 650; }
	.indicator { flex: 0 0 auto; color: var(--color-ink-muted); font-size: 1.35rem; font-weight: 350; }
	.qa-trigger[aria-expanded="true"] .indicator { color: var(--color-accent); }
	.answer { padding: 0 3.3rem 1.35rem; }
	.answer p { margin: 0; white-space: pre-line; line-height: 1.7; }
	.empty-state, .not-found { padding: 3rem 1rem; color: var(--color-ink-muted); text-align: center; }
	.not-found h1 { color: var(--color-ink); }
	.visually-hidden { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; clip-path: inset(50%); }
	[hidden] { display: none !important; }

	@media (max-width: 38rem) {
		.filters { grid-template-columns: 1fr; }
		.qa-trigger { padding: 1rem; }
		.answer { padding: 0 2.8rem 1.15rem; }
	}

	@media (prefers-reduced-motion: reduce) {
		html { scroll-behavior: auto; }
		* { transition-duration: 0s !important; }
	}
</style>
